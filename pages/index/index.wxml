<view class="index-page">
  <!-- 顶部背景 -->
  <view class="top-section">
    <view class="top-gradient">
      <view class="heart-icon">💗</view>
      <view class="main-title">亲密关系依恋风格测评</view>
      <view class="main-subtitle">探索你在关系中的情绪模式与舒适区边界</view>
    </view>
  </view>

  <!-- 内容区 -->
  <view class="content-section">
    <!-- 测评说明卡片 -->
    <view class="intro-card">
      <view class="intro-title">测评说明</view>
      <view class="intro-text">本测评共 24 道题，约需 5 分钟完成。</view>
      <view class="intro-tip">
        <text>💡 请根据你大多数时候的感受作答，没有对错之分</text>
      </view>
    </view>

    <!-- 测评特点 -->
    <view class="features-row">
      <view class="feature-badge">
        <text class="badge-num">24</text>
        <text class="badge-text">道题目</text>
      </view>
      <view class="feature-badge">
        <text class="badge-num">~5</text>
        <text class="badge-text">分钟</text>
      </view>
      <view class="feature-badge">
        <text class="badge-num">4</text>
        <text class="badge-text">种类型</text>
      </view>
    </view>

    <!-- 警示说明 -->
    <view class="warning-card">
      <view class="warning-title">⚠️ 重要提示</view>
      <view class="warning-text">本测评采用轻度迫选设计，可能会放大你的倾向，请结合自我感受综合判断。</view>
      <view class="warning-text" style="margin-top: 12rpx;">结果仅供自我觉察参考，不构成临床诊断。</view>
    </view>

    <!-- 开始按钮 -->
    <button class="start-btn" bindtap="startTest">开始测评</button>

    <!-- 免责声明 -->
    <view class="disclaimer">
      <text>本测评仅用于自我认知探索，不构成专业心理诊断</text>
    </view>
  </view>
</view>
