/* 首页样式 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #F5A3A3 0%, #FFF8F0 30%);
  display: flex;
  flex-direction: column;
}

/* 头部区域 */
.header {
  padding: 80rpx 40rpx 60rpx;
  text-align: center;
}

.heart-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  animation: beat 1.5s ease-in-out infinite;
}

@keyframes beat {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

.header-title {
  font-size: 52rpx;
  font-weight: 700;
  color: #fff;
  text-shadow: 0 4rpx 12rpx rgba(0,0,0,0.15);
  margin-bottom: 12rpx;
}

.header-subtitle {
  font-size: 28rpx;
  color: rgba(255,255,255,0.85);
}

/* 主内容 */
.main-content {
  flex: 1;
  padding: 40rpx;
}

.welcome-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 48rpx 32rpx;
  box-shadow: 0 8rpx 40rpx rgba(245,163,163,0.15);
  text-align: center;
}

.welcome-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 16rpx;
}

.welcome-desc {
  font-size: 28rpx;
  color: #999;
  line-height: 1.6;
  margin-bottom: 40rpx;
}

/* 特点列表 */
.features {
  display: flex;
  justify-content: space-around;
  margin-bottom: 48rpx;
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.feature-icon {
  width: 88rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #FFF0F0, #FFF8F0);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 12rpx;
}

.feature-text {
  font-size: 24rpx;
  color: #666;
}

/* 开始按钮 */
.start-btn {
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  background: linear-gradient(135deg, #F5A3A3, #E8A0A0);
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  border: none;
  border-radius: 50rpx;
  box-shadow: 0 8rpx 30rpx rgba(245,163,163,0.4);
}

.start-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 20rpx rgba(245,163,163,0.3);
}

/* 免责声明 */
.disclaimer {
  padding: 40rpx;
  text-align: center;
}

.disclaimer text {
  font-size: 22rpx;
  color: #bbb;
  line-height: 1.8;
}