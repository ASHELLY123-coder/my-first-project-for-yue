/* 个人中心样式 */
page {
  background: #FFF8F0;
}

.profile-page {
  padding-bottom: 60rpx;
}

/* 用户信息区 */
.user-section {
  display: flex;
  align-items: center;
  padding: 48rpx 32rpx;
  background: linear-gradient(135deg, #F5A3A3, #E8A0A0);
}

.avatar-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 24rpx;
  border: 4rpx solid rgba(255,255,255,0.5);
}

.avatar {
  width: 100%;
  height: 100%;
}

.default-avatar {
  background: rgba(255,255,255,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-text {
  font-size: 60rpx;
}

.user-info { flex: 1; }

.nickname {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8rpx;
}

.user-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}

.btn-login {
  background: rgba(255,255,255,0.25);
  color: #fff;
  border: 2rpx solid rgba(255,255,255,0.5);
  border-radius: 40rpx;
  font-size: 26rpx;
  padding: 14rpx 36rpx;
}

/* 分区卡片 */
.section {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

/* 历史记录 */
.history-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.history-item:last-child {
  border-bottom: none;
}

.history-type {
  display: block;
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.history-date {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.history-arrow {
  font-size: 36rpx;
  color: #ddd;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 60rpx 0;
}

.empty-icon {
  display: block;
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  display: block;
  font-size: 30rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.empty-hint {
  display: block;
  font-size: 24rpx;
  color: #ccc;
}

/* 菜单项 */
.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
}

.menu-item text:first-child {
  font-size: 30rpx;
  color: #333;
}

.menu-arrow {
  font-size: 36rpx;
  color: #ddd;
}

/* 免责声明 */
.disclaimer {
  padding: 32rpx;
  text-align: center;
}

.disclaimer text {
  font-size: 22rpx;
  color: #bbb;
  line-height: 1.8;
}