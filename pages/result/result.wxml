<view class="result-page">
  <!-- 顶部 -->
  <view class="result-header" style="background: linear-gradient(135deg, {{resultData.color}}, {{resultData.color}}aa)">
    <view class="type-badge">你的依恋类型</view>
    <view class="type-name">{{resultData.emoji}} {{resultData.typeName}}</view>
    <view class="type-subtitle">{{resultData.subtitle}}</view>
  </view>

  <view class="result-body">
    <!-- 分数条 -->
    <view class="score-section">
      <view class="score-title">📊 测评结果</view>

      <view class="score-item">
        <view class="score-label">
          <text class="score-name">焦虑倾向</text>
          <text class="score-value">{{anxiousScore}}分</text>
        </view>
        <view class="score-bar-bg">
          <view class="score-bar" style="width: {{anxietyBarWidth}}%; background: #E67E22"></view>
        </view>
        <view class="score-level">等级：{{anxietyLevel}}</view>
      </view>

      <view class="score-item">
        <view class="score-label">
          <text class="score-name">回避倾向</text>
          <text class="score-value">{{avoidantScore}}分</text>
        </view>
        <view class="score-bar-bg">
          <view class="score-bar" style="width: {{avoidanceBarWidth}}%; background: #3498DB"></view>
        </view>
        <view class="score-level">等级：{{avoidanceLevel}}</view>
      </view>
    </view>

    <!-- 饼图区域 -->
    <view class="pie-section">
      <view class="pie-title">焦虑 vs 回避 分布</view>
      <view class="pie-container">
        <view class="pie-chart">
          <view class="pie-anxiety" style="background: #E67E22"></view>
          <view class="pie-avoidance" style="background: #3498DB"></view>
        </view>
        <view class="pie-legend">
          <view class="legend-item">
            <view class="legend-dot" style="background: #E67E22"></view>
            <text class="legend-text">焦虑倾向</text>
            <text class="legend-value">{{anxiousScore}}分</text>
          </view>
          <view class="legend-item">
            <view class="legend-dot" style="background: #3498DB"></view>
            <text class="legend-text">回避倾向</text>
            <text class="legend-value">{{avoidantScore}}分</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 特征描述 -->
    <view class="desc-section">
      <view class="section-title">📝 你是怎样的</view>
      <view class="desc-text">{{resultData.description}}</view>
    </view>

    <!-- 暖心建议 -->
    <view class="advice-section">
      <view class="section-title">💡 暖心建议</view>
      <view class="advice-main">{{resultData.advice}}</view>
      <view class="tips-list">
        <view class="tip-item" wx:for="{{resultData.tips}}" wx:key="index">· {{item}}</view>
      </view>
      <view class="book-tip">📚 推荐阅读：{{resultData.book}}</view>
    </view>

    <!-- 心理支持 -->
    <view class="hotline-section">
      <view class="hotline-title">📞 心理支持资源</view>
      <view class="hotline-item">全国心理援助热线：400-161-9995</view>
      <view class="hotline-item">简单心理平台（预约专业咨询师）</view>
    </view>

    <!-- 隐私说明 -->
    <view class="privacy-section">
      <text class="privacy-text">本测评结果仅保存在你的本地设备中，不会上传至服务器。如需帮助，请寻求专业心理咨询。</text>
    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="result-footer">
    <button class="share-btn" open-type="share">分享给朋友</button>
    <button class="home-btn" bindtap="goHome">返回首页</button>
  </view>
</view>
