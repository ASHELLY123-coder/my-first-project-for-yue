<!-- pages/result/result.wxml -->
<scroll-view scroll-y class="result-page" style="background: #FFF8F0;">
  <!-- 顶部结果展示 -->
  <view class="result-header" style="background: linear-gradient(180deg, {{typeColor}} 0%, #FFF8F0 100%);">
    <view class="result-badge">
      <text class="badge-text">你的依恋风格</text>
    </view>
    <view class="type-emoji">{{result.emoji}}</view>
    <view class="type-name" style="color: #fff;">{{result.typeName}}</view>
    <view class="type-subtitle">{{result.subtitle}}</view>
  </view>

  <!-- 饼状图 -->
  <view class="card chart-card">
    <view class="card-title">得分占比</view>
    <view class="pie-container">
      <view class="pie-chart" style="background: conic-gradient(#E67E22 0% {{anxietyScore / (anxietyScore + avoidanceScore) * 100 || 50}}%, #3498DB {{anxietyScore / (anxietyScore + avoidanceScore) * 100 || 50}}% 100%);">
        <view class="pie-center">
          <text class="pie-total">{{anxietyScore + avoidanceScore}}</text>
          <text class="pie-label">总分</text>
        </view>
      </view>
      <view class="pie-legend">
        <view class="legend-item">
          <view class="legend-dot" style="background: #E67E22;"></view>
          <text>焦虑 {{anxietyScore}}分</text>
        </view>
        <view class="legend-item">
          <view class="legend-dot" style="background: #3498DB;"></view>
          <text>回避 {{avoidanceScore}}分</text>
        </view>
      </view>
    </view>
    <view class="score-note">
      <text>阈值：单项 > 30分为高倾向（满分48）</text>
    </view>
  </view>

  <!-- 特征描述 -->
  <view class="card">
    <view class="card-title">特征解读</view>
    <view class="feature-item" wx:for="{{result.features}}" wx:key="index">
      <text class="feature-dot">•</text>
      <text class="feature-text">{{item}}</text>
    </view>
  </view>

  <!-- 核心描述 -->
  <view class="card desc-card" style="border-left: 6rpx solid {{typeColor}};">
    <view class="desc-text">{{result.description}}</view>
  </view>

  <!-- 暖心建议 -->
  <view class="card">
    <view class="card-title">暖心建议</view>
    <view class="advice-text">{{result.advice}}</view>
  </view>

  <!-- 小练习 -->
  <view class="card">
    <view class="card-title">一些小练习</view>
    <view class="tip-item" wx:for="{{result.tips}}" wx:key="index">
      <view class="tip-num">{{index + 1}}</view>
      <text class="tip-text">{{item}}</text>
    </view>
  </view>

  <!-- 伦理声明 -->
  <view class="card ethics-card">
    <view class="ethics-title">免责声明</view>
    <view class="ethics-text">本测评仅用于自我认知探索，不构成临床诊断。如需帮助请咨询专业心理咨询师。</view>
    <view class="ethics-title" style="margin-top: 20rpx;">隐私说明</view>
    <view class="ethics-text">结果仅保存在本地，不上传服务器。</view>
  </view>

  <!-- 心理支持渠道 -->
  <view class="card support-card">
    <view class="card-title">心理支持渠道</view>
    <view class="support-item" wx:for="{{supportChannels}}" wx:key="name">
      <view class="support-main">
        <text class="support-name">{{item.name}}</text>
        <text class="support-phone" wx:if="{{item.phone}}">{{item.phone}}</text>
      </view>
    </view>
  </view>

  <!-- 分享 & 返回 -->
  <view class="bottom-btns">
    <button class="btn-share" open-type="share">分享给朋友</button>
    <button class="btn-home" bindtap="goHome">再做一次</button>
  </view>

  <view class="page-bottom"></view>
</scroll-view>
