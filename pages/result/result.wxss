page { background: #FFF8F0; }

.result-page { min-height: 100vh; padding-bottom: 140rpx; }

.result-header {
  padding: 60rpx 40rpx 50rpx;
  text-align: center;
  color: #fff;
  border-radius: 0 0 40rpx 40rpx;
}
.type-badge { font-size: 24rpx; opacity: 0.85; margin-bottom: 16rpx; }
.type-name { font-size: 52rpx; font-weight: 700; margin-bottom: 8rpx; }
.type-subtitle { font-size: 26rpx; opacity: 0.85; }

.result-body { padding: 32rpx 32rpx 0; }

.core-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  text-align: center;
}
.core-tag {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}
.core-text {
  font-size: 36rpx;
  color: #333;
  font-weight: 600;
  line-height: 1.6;
}

.desc-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}
.section-title { font-size: 30rpx; font-weight: 600; color: #333; margin-bottom: 20rpx; }
.desc-text { font-size: 30rpx; color: #555; line-height: 1.9; white-space: pre-line; }

.monologue-section {
  background: linear-gradient(135deg, #fdf6f3, #faf5f2);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #f0e8e5;
}
.monologue-label {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}
.monologue-text {
  font-size: 30rpx;
  color: #666;
  font-style: italic;
  line-height: 1.8;
  text-align: center;
}

.score-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}
.score-title { font-size: 30rpx; font-weight: 600; color: #333; margin-bottom: 28rpx; }
.score-item { margin-bottom: 28rpx; }
.score-item:last-child { margin-bottom: 0; }
.score-label { display: flex; justify-content: space-between; margin-bottom: 12rpx; }
.score-name { font-size: 28rpx; color: #555; }
.score-value { font-size: 28rpx; font-weight: 600; color: #333; }
.score-bar-bg { height: 16rpx; background: #f0f0f0; border-radius: 8rpx; overflow: hidden; }
.score-bar { height: 100%; border-radius: 8rpx; transition: width 1s ease; }
.score-level { font-size: 22rpx; color: #aaa; margin-top: 8rpx; text-align: right; }

.advice-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}
.advice-main { font-size: 30rpx; color: #555; line-height: 1.8; margin-bottom: 28rpx; }
.tips-list { margin-bottom: 24rpx; }
.tip-item { font-size: 28rpx; color: #666; line-height: 1.9; margin-bottom: 16rpx; padding-left: 8rpx; }
.book-tip { font-size: 26rpx; color: #999; padding-top: 16rpx; border-top: 1rpx solid #f0f0f0; }

.hotline-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}
.hotline-title { font-size: 30rpx; font-weight: 600; color: #333; margin-bottom: 20rpx; }
.hotline-item { font-size: 28rpx; color: #555; line-height: 1.8; }

.detail-section {
  background: #f9f9f9;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}
.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
}
.detail-title { font-size: 26rpx; color: #999; }
.detail-toggle { font-size: 26rpx; color: #666; }
.detail-content { padding: 0 28rpx 24rpx; }
.detail-item { font-size: 26rpx; color: #666; line-height: 1.8; }
.detail-note { font-size: 22rpx; color: #bbb; margin-top: 16rpx; line-height: 1.6; }

.privacy-section { padding: 0 16rpx 24rpx; }
.privacy-text { font-size: 22rpx; color: #bbb; text-align: center; line-height: 1.6; }

.result-footer {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx;
  background: rgba(255,248,240,0.95);
  backdrop-filter: blur(10rpx);
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}
.share-btn {
  flex: 1;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #F5A3A3, #E8A0A0);
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  box-shadow: 0 6rpx 24rpx rgba(245,163,163,0.4);
}
.home-btn {
  flex: 1;
  height: 96rpx;
  line-height: 96rpx;
  background: #fff;
  color: #666;
  border-radius: 48rpx;
  font-size: 32rpx;
  border: 2rpx solid #e0e0e0;
}
button::after { border: none; }