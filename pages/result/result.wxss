page { background: #FFF8F0; }

.result-page { min-height: 100vh; padding-bottom: 140rpx; }

.result-header {
  padding: 60rpx 40rpx 50rpx;
  text-align: center;
  color: #fff;
  border-radius: 0 0 40rpx 40rpx;
}
.type-badge { font-size: 24rpx; opacity: 0.85; margin-bottom: 16rpx; }
.type-name { font-size: 52rpx; font-weight: 700; margin-bottom: 8rpx; }
.type-subtitle { font-size: 26rpx; opacity: 0.85; }

.result-body { padding: 32rpx 32rpx 0; }

.score-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}
.score-title { font-size: 30rpx; font-weight: 600; color: #333; margin-bottom: 28rpx; }
.score-item { margin-bottom: 28rpx; }
.score-item:last-child { margin-bottom: 0; }
.score-label { display: flex; justify-content: space-between; margin-bottom: 12rpx; }
.score-name { font-size: 28rpx; color: #555; }
.score-value { font-size: 28rpx; font-weight: 600; color: #333; }
.score-bar-bg { height: 16rpx; background: #f0f0f0; border-radius: 8rpx; overflow: hidden; }
.score-bar { height: 100%; border-radius: 8rpx; transition: width 1s ease; }
.score-level { font-size: 22rpx; color: #aaa; margin-top: 8rpx; text-align: right; }

.pie-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}
.pie-title { font-size: 30rpx; font-weight: 600; color: #333; margin-bottom: 28rpx; }
.pie-container { display: flex; align-items: center; gap: 32rpx; }
.pie-chart {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  position: relative;
  background: #3498DB;
  overflow: hidden;
  flex-shrink: 0;
}
.pie-anxiety {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  border-radius: 50%;
  opacity: 0.5;
}
.pie-avoidance {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  border-radius: 50%;
  opacity: 0.7;
}
.pie-legend { flex: 1; }
.legend-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  font-size: 28rpx;
}
.legend-dot { width: 20rpx; height: 20rpx; border-radius: 50%; margin-right: 12rpx; flex-shrink: 0; }
.legend-text { color: #555; flex: 1; }
.legend-value { font-weight: 600; color: #333; }

.desc-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}
.section-title { font-size: 30rpx; font-weight: 600; color: #333; margin-bottom: 20rpx; }
.desc-text { font-size: 30rpx; color: #555; line-height: 1.8; }

.advice-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}
.advice-main { font-size: 30rpx; color: #555; line-height: 1.8; margin-bottom: 28rpx; }
.tips-list { margin-bottom: 24rpx; }
.tip-item { font-size: 28rpx; color: #666; line-height: 1.8; margin-bottom: 8rpx; padding-left: 8rpx; }
.book-tip { font-size: 26rpx; color: #999; padding-top: 16rpx; border-top: 1rpx solid #f0f0f0; }

.hotline-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}
.hotline-title { font-size: 30rpx; font-weight: 600; color: #333; margin-bottom: 20rpx; }
.hotline-item { font-size: 28rpx; color: #555; line-height: 1.8; }

.privacy-section { padding: 0 16rpx 24rpx; }
.privacy-text { font-size: 22rpx; color: #bbb; text-align: center; line-height: 1.6; }

.result-footer {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx;
  background: rgba(255,248,240,0.95);
  backdrop-filter: blur(10rpx);
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}
.share-btn {
  flex: 1;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #F5A3A3, #E8A0A0);
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  box-shadow: 0 6rpx 24rpx rgba(245,163,163,0.4);
}
.home-btn {
  flex: 1;
  height: 96rpx;
  line-height: 96rpx;
  background: #fff;
  color: #666;
  border-radius: 48rpx;
  font-size: 32rpx;
  border: 2rpx solid #e0e0e0;
}
button::after { border: none; }
