/* 结果页样式 */
page {
  background: #FFF8F0;
}

.result-page {
  padding-bottom: 120rpx;
}

/* 顶部结果展示 */
.result-header {
  padding: 60rpx 40rpx 80rpx;
  background: linear-gradient(180deg, var(--theme-color, #F5A3A3) 0%, #FFF8F0 100%);
  text-align: center;
  position: relative;
}

.type-badge {
  display: inline-block;
  padding: 10rpx 28rpx;
  background: rgba(255,255,255,0.9);
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 24rpx;
}

.type-name {
  font-size: 56rpx;
  font-weight: 700;
  color: #fff;
  text-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
  margin-bottom: 20rpx;
}

.type-subtitle {
  font-size: 30rpx;
  color: rgba(255,255,255,0.9);
  line-height: 1.6;
  padding: 0 40rpx;
}

/* 分数卡片 */
.score-card {
  margin: -40rpx 24rpx 24rpx;
  position: relative;
  z-index: 10;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 28rpx;
  padding-left: 20rpx;
  border-left: 6rpx solid var(--theme-color, #F5A3A3);
}

.score-bar-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.score-bar-row .label {
  width: 110rpx;
  font-size: 26rpx;
  color: #666;
}

.score-bar-row .bar-track {
  flex: 1;
  height: 16rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  margin: 0 16rpx;
  overflow: hidden;
}

.score-bar-row .bar-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.6s ease;
}

.score-bar-row .score-num {
  width: 80rpx;
  font-size: 26rpx;
  color: #999;
  text-align: right;
}

/* 内容卡片 */
.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 0 24rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.feature-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.feature-dot {
  color: var(--theme-color, #F5A3A3);
  font-size: 20rpx;
  margin-right: 12rpx;
  margin-top: 8rpx;
}

.feature-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.7;
  flex: 1;
}

.desc-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
}

.advice-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.advice-num {
  color: var(--theme-color, #F5A3A3);
  font-size: 28rpx;
  font-weight: 600;
  margin-right: 12rpx;
}

.advice-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.7;
  flex: 1;
}

/* 底部按钮 */
.bottom-btns {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx 24rpx 40rpx;
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.05);
  gap: 20rpx;
}

.btn-share, .btn-home {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
}

.btn-share {
  background: linear-gradient(135deg, #A3D0C0, #8BC0A8);
  color: #fff;
}

.btn-home {
  background: #f5f5f5;
  color: #666;
}

/* 免责声明 */
.disclaimer {
  padding: 40rpx 24rpx;
  text-align: center;
}

.disclaimer text {
  font-size: 22rpx;
  color: #bbb;
  line-height: 1.8;
}