page { background: #FFF8F0; }
.result-page { height: 100vh; }

.result-header { text-align: center; padding: 60rpx 40rpx 80rpx; }
.result-badge { display: inline-block; padding: 10rpx 28rpx; background: rgba(255,255,255,0.85); border-radius: 24rpx; font-size: 24rpx; color: #666; margin-bottom: 20rpx; }
.type-emoji { font-size: 100rpx; margin-bottom: 16rpx; }
.type-name { display: block; font-size: 56rpx; font-weight: 700; text-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1); margin-bottom: 12rpx; }
.type-subtitle { display: block; font-size: 30rpx; color: rgba(255,255,255,0.9); }

.card { background: #fff; border-radius: 24rpx; padding: 32rpx; margin: 0 24rpx 24rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06); }
.card-title { font-size: 32rpx; font-weight: 600; color: #333; margin-bottom: 24rpx; padding-left: 16rpx; border-left: 6rpx solid #F5A3A3; }

/* 饼图 */
.pie-container { display: flex; flex-direction: column; align-items: center; padding: 20rpx 0; }
.pie-chart { width: 280rpx; height: 280rpx; border-radius: 50%; position: relative; }
.pie-center { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 160rpx; height: 160rpx; background: #fff; border-radius: 50%; display: flex; flex-direction: column; align-items: center; justify-content: center; }
.pie-total { font-size: 48rpx; font-weight: 700; color: #333; }
.pie-label { font-size: 22rpx; color: #999; margin-top: 4rpx; }
.pie-legend { display: flex; gap: 40rpx; margin-top: 24rpx; }
.legend-item { display: flex; align-items: center; font-size: 26rpx; color: #666; }
.legend-dot { width: 20rpx; height: 20rpx; border-radius: 4rpx; margin-right: 10rpx; }
.score-note { text-align: center; font-size: 22rpx; color: #bbb; margin-top: 20rpx; padding-top: 16rpx; border-top: 1rpx solid #f5f5f5; }

/* 特征 */
.feature-item { display: flex; align-items: flex-start; margin-bottom: 16rpx; }
.feature-dot { color: #F5A3A3; font-size: 24rpx; margin-right: 12rpx; margin-top: 4rpx; }
.feature-text { font-size: 28rpx; color: #555; line-height: 1.7; flex: 1; }

.desc-card { }
.desc-text { font-size: 30rpx; color: #555; line-height: 1.8; font-style: italic; }

.advice-text { font-size: 28rpx; color: #555; line-height: 1.8; }

/* 小练习 */
.tip-item { display: flex; align-items: flex-start; margin-bottom: 20rpx; }
.tip-num { width: 48rpx; height: 48rpx; line-height: 48rpx; text-align: center; background: linear-gradient(135deg, #F5A3A3, #E8A0A0); color: #fff; border-radius: 50%; font-size: 24rpx; font-weight: 600; margin-right: 16rpx; flex-shrink: 0; }
.tip-text { font-size: 28rpx; color: #555; line-height: 1.7; flex: 1; padding-top: 8rpx; }

/* 伦理 */
.ethics-card { background: #FFF8F0; }
.ethics-title { font-size: 26rpx; font-weight: 600; color: #666; margin-bottom: 8rpx; }
.ethics-text { font-size: 24rpx; color: #888; line-height: 1.7; }

/* 心理支持 */
.support-item { padding: 16rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.support-item:last-child { border-bottom: none; }
.support-main { display: flex; flex-direction: column; }
.support-name { font-size: 28rpx; color: #333; font-weight: 500; }
.support-phone { font-size: 26rpx; color: #E67E22; margin-top: 6rpx; }

/* 底部按钮 */
.bottom-btns { display: flex; padding: 20rpx 24rpx 40rpx; gap: 20rpx; }
.btn-share { flex: 1; height: 88rpx; line-height: 88rpx; background: linear-gradient(135deg, #A3D0C0, #8BC0A8); color: #fff; border: none; border-radius: 44rpx; font-size: 30rpx; font-weight: 500; }
.btn-home { flex: 1; height: 88rpx; line-height: 88rpx; background: #fff; color: #666; border: 2rpx solid #e0e0e0; border-radius: 44rpx; font-size: 30rpx; }

.page-bottom { height: 60rpx; }
