page { background: #FFF8F0; height: 100%; }
.test-page { min-height: 100vh; display: flex; flex-direction: column; }

.progress-section { padding: 32rpx 40rpx 20rpx; background: #fff; }
.progress-info { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.progress-text { font-size: 28rpx; color: #333; font-weight: 600; }
.progress-tip { font-size: 24rpx; color: #E67E22; }
.progress-tip.avoidant { color: #3498DB; }
.progress-bar { height: 10rpx; background: #f0f0f0; border-radius: 5rpx; overflow: hidden; }
.progress-fill { height: 100%; background: linear-gradient(90deg, #F5A3A3, #A3D0C0); border-radius: 5rpx; transition: width 0.4s ease; }

.question-card { margin: 24rpx; padding: 40rpx 32rpx; background: #fff; border-radius: 24rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06); }
.question-number { font-size: 26rpx; color: #999; margin-bottom: 16rpx; }
.question-text { font-size: 34rpx; color: #333; line-height: 1.7; font-weight: 500; }

.options-section { padding: 0 24rpx; flex: 1; }
.option-item { 
  display: flex; 
  align-items: flex-start; 
  padding: 24rpx; 
  margin-bottom: 16rpx; 
  background: #fff; 
  border: 3rpx solid #f0f0f0; 
  border-radius: 16rpx; 
  transition: all 0.3s ease; 
  position: relative; 
}
.option-item.selected { 
  background: linear-gradient(135deg, rgba(245,163,163,0.15), rgba(245,163,163,0.08)); 
  border-color: #F5A3A3;
  box-shadow: 0 4rpx 16rpx rgba(245,163,163,0.25);
}

.option-label { 
  width: 56rpx; 
  height: 56rpx; 
  line-height: 56rpx; 
  text-align: center; 
  background: #f5f5f5; 
  border-radius: 50%; 
  font-size: 28rpx; 
  color: #999; 
  margin-right: 16rpx; 
  flex-shrink: 0; 
  transition: all 0.3s ease; 
  border: 2rpx solid transparent;
}
.option-item.selected .option-label { 
  background: linear-gradient(135deg, #F5A3A3, #E8A0A0); 
  color: #fff; 
  border-color: #E8A0A0;
  transform: scale(1.1);
}

.option-text { 
  font-size: 28rpx; 
  color: #444; 
  line-height: 1.6; 
  flex: 1; 
  padding-top: 12rpx;
  transition: color 0.3s ease;
}
.option-item.selected .option-text {
  color: #333;
  font-weight: 500;
}

.option-check { 
  position: absolute; 
  right: 20rpx; 
  top: 50%; 
  transform: translateY(-50%); 
  width: 44rpx; 
  height: 44rpx; 
  line-height: 44rpx; 
  text-align: center; 
  background: linear-gradient(135deg, #F5A3A3, #E8A0A0); 
  color: #fff; 
  border-radius: 50%; 
  font-size: 26rpx;
  font-weight: bold;
}

.nav-section { display: flex; padding: 24rpx; gap: 20rpx; }
.nav-btn { flex: 1; height: 96rpx; line-height: 96rpx; border-radius: 48rpx; font-size: 32rpx; font-weight: 500; border: none; }
.prev-btn { background: #fff; color: #666; border: 2rpx solid #e0e0e0; }
.next-btn { background: linear-gradient(135deg, #F5A3A3, #E8A0A0); color: #fff; box-shadow: 0 6rpx 24rpx rgba(245,163,163,0.3); }

.test-tip { padding: 16rpx; text-align: center; }
.test-tip text { font-size: 22rpx; color: #bbb; }
