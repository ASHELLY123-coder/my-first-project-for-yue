<!-- pages/test/test.wxml -->
<view class="container">
  <view class="progress-section">
    <view class="progress-text">{{currentIndex + 1}} / 30</view>
    <view class="progress-bar">
      <view class="progress-fill" style="width: {{((currentIndex + 1) / 30 * 100) + '%'}}"></view>
    </view>
  </view>

  <view class="question-section">
    <view class="question-number">第 {{currentIndex + 1}} 题</view>
    <view class="question-text">{{currentQuestion.text}}</view>
  </view>

  <view class="options-section">
    <view class="option-item {{selectedOption === 1 ? 'selected' : ''}}" data-score="1" bindtap="selectOption">
      <view class="option-circle">1</view>
      <view class="option-label">完全不同意</view>
    </view>
    <view class="option-item {{selectedOption === 2 ? 'selected' : ''}}" data-score="2" bindtap="selectOption">
      <view class="option-circle">2</view>
      <view class="option-label">不同意</view>
    </view>
    <view class="option-item {{selectedOption === 3 ? 'selected' : ''}}" data-score="3" bindtap="selectOption">
      <view class="option-circle">3</view>
      <view class="option-label">中立</view>
    </view>
    <view class="option-item {{selectedOption === 4 ? 'selected' : ''}}" data-score="4" bindtap="selectOption">
      <view class="option-circle">4</view>
      <view class="option-label">同意</view>
    </view>
    <view class="option-item {{selectedOption === 5 ? 'selected' : ''}}" data-score="5" bindtap="selectOption">
      <view class="option-circle">5</view>
      <view class="option-label">完全同意</view>
    </view>
  </view>

  <view class="nav-section">
    <button class="nav-btn prev-btn" bindtap="prevQuestion" disabled="{{currentIndex === 0}}">上一题</button>
    <button class="nav-btn next-btn" bindtap="nextQuestion">{{currentIndex === 29 ? '查看结果' : '下一题'}}</button>
  </view>
</view>