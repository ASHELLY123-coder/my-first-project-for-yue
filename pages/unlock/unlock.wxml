<!--pages/unlock/unlock.wxml-->
<view class="unlock-page">
  <view class="preview-card card">
    <view class="type-badge">你的依恋类型</view>
    <text class="type-name">{{typeKey === 'anxious' ? '焦虑型' : typeKey === 'avoidant' ? '回避型' : typeKey === 'secure' ? '安全型' : '混合型'}}</text>
    <view class="blurred-content">
      <view class="blur-block"></view>
      <view class="blur-block short"></view>
      <view class="blur-block"></view>
      <view class="blur-block medium"></view>
    </view>
  </view>

  <view class="method-card card">
    <text class="method-title">选择解锁方式</text>

    <view class="method-item" bindtap="payUnlock">
      <view class="method-icon">💎</view>
      <view class="method-info">
        <text class="method-name">付费解锁</text>
        <text class="method-desc">永久解锁完整报告与个性化建议</text>
      </view>
      <view class="method-price">
        <text class="price">¥9.9</text>
        <text class="price-tag">一次购买</text>
      </view>
    </view>

    <view class="divider">
      <view class="divider-line"></view>
      <text class="divider-text">或者</text>
      <view class="divider-line"></view>
    </view>

    <button class="btn-invite" open-type="share">
      <text>🎁 邀请好友解锁</text>
      <text class="invite-hint">分享给1位好友完成测试即可免费解锁</text>
    </button>
  </view>

  <view class="disclaimer">
    <text>支付完成后可永久查看所有测评报告。如有问题请联系客服。</text>
  </view>
</view>